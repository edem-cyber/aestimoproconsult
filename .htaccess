RewriteEngine On

# Route root to api/index.php
RewriteRule ^$ api/index.php [L]
RewriteRule ^index/?$ api/index.php [L]

# Route main pages to their API counterparts
RewriteRule ^demo-consulting-company/?$ api/demo-consulting-company.php [L]
RewriteRule ^demo-consulting-contact/?$ api/demo-consulting-contact.php [L]
RewriteRule ^demo-consulting-process/?$ api/demo-consulting-process.php [L]
RewriteRule ^demo-consulting-services/?$ api/demo-consulting-services.php [L]
RewriteRule ^demo-consulting-services-details/?$ api/demo-consulting-services-details.php [L]

# Allow direct access to static assets (CSS, JS, images, fonts, etc.)
RewriteRule \.(css|js|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|mp4|webm|pdf)$ - [L]

# Fallback to api directory for any other PHP requests
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/api/
RewriteRule ^(.*)\.php$ api/$1.php [L]

# Set default document
DirectoryIndex index.php index.html

# Enable compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
</IfModule>

# Website Protection - Aestimo Pro Consult
# Prevent directory browsing and unauthorized access

# Disable directory listing
Options -Indexes

# Prevent access to sensitive files
<Files ~ "(\.htaccess|\.htpasswd|\.env|config\.php|database\.php|functions\.php)$">
    Order allow,deny
    Deny from all
</Files>

# Prevent access to backup and temporary files
<FilesMatch "\.(bak|backup|tmp|temp|log|sql|zip|tar|gz|rar)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block suspicious user agents and crawlers that might download sites
RewriteCond %{HTTP_USER_AGENT} (wget|curl|lynx|httrack|winhttrack|webcopier|webcopy|offline|extract|download|spider|crawl|harvest|grab|suck) [NC]
RewriteRule ^.* - [F,L]

# Block requests with suspicious query strings
RewriteCond %{QUERY_STRING} (wget|curl|download|extract|copy|mirror) [NC]
RewriteRule ^.* - [F,L]

# Prevent hotlinking of images and assets
RewriteCond %{HTTP_REFERER} !^$
RewriteCond %{HTTP_REFERER} !^https://(www\.)?aestimoproconsult\.vercel\.app [NC]
RewriteCond %{HTTP_REFERER} !^https://(www\.)?localhost [NC]
RewriteRule \.(jpg|jpeg|png|gif|svg|css|js|pdf)$ - [F,L]

# Block access to source code files
<FilesMatch "\.(php|inc|class)$">
    RewriteEngine On
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteCond %{HTTP_REFERER} !^https://(www\.)?aestimoproconsult\.vercel\.app [NC]
    RewriteCond %{HTTP_REFERER} !^$
    RewriteRule ^.* - [F,L]
</FilesMatch>

# Prevent access to includes and layouts directories from external requests
RewriteCond %{THE_REQUEST} \s/+(includes|layouts|email-templates)/ [NC]
RewriteRule ^ - [F,L]

# Block common site ripping tools
RewriteCond %{HTTP_USER_AGENT} ^BlackWidow [OR]
RewriteCond %{HTTP_USER_AGENT} ^Bot\ mailto:craftbot@yahoo.com [OR]
RewriteCond %{HTTP_USER_AGENT} ^ChinaClaw [OR]
